{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node prisma-prepare.js && prisma generate && next dev",
    "build": "node prisma-prepare.js && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "electron:start": "electron .",
    "electron:pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@aws-sdk/lib-storage": "^3.1061.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.107.0",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "multer": "^2.1.1",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.maven.tradingjournal",
    "productName": "Maven Trading Journal",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!src/**/*",
      "!tsconfig.json",
      "!.next/cache/**/*",
      "!.next/dev/**/*"
    ],
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
